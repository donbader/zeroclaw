# Secrets only — never commit this file.
API_KEY=your-openrouter-or-provider-api-key
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token

# GitHub token — enables git clone/push and gh CLI (PRs, issues, etc.)
# GITHUB_TOKEN=ghp_your-github-token
# GIT_USER_NAME=Dorey
# GIT_USER_EMAIL=doreyortea@gmail.com

# Set to "true" to overwrite workspace identity files on next restart.
# Remove or set to anything else after reset to preserve runtime edits.
# RESET_WORKSPACE=true
